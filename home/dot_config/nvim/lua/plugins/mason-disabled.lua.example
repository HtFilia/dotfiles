-- ~/.config/nvim/lua/plugins/mason-disabled.lua.disabled
-- Rename this file to "mason-disabled.lua" (drop the .disabled suffix)
-- on restricted/corporate machines where Mason cannot reach the URLs it
-- needs to download LSP servers / formatters / linters.
--
-- After disabling Mason, install LSPs via apt instead, e.g.:
--   sudo apt install python3-lsp-server gopls rust-analyzer
--
-- See docs/RESTRICTED-MODE.md for more details.

return {
  { "williamboman/mason.nvim", enabled = false },
  { "williamboman/mason-lspconfig.nvim", enabled = false },
  { "jay-babu/mason-nvim-dap.nvim", enabled = false },

  -- Tell nvim-lspconfig to skip the "automatic setup via Mason" step
  {
    "neovim/nvim-lspconfig",
    opts = function(_, opts)
      opts.setup = opts.setup or {}
      -- Use system-installed language servers directly
      return opts
    end,
  },

  -- Replace LazyVim's default formatters that rely on Mason downloads
  -- with whatever is on $PATH from apt.
  {
    "stevearc/conform.nvim",
    opts = function(_, opts)
      opts.formatters_by_ft = opts.formatters_by_ft or {}
      -- Only register formatters known to be apt-installable
      opts.formatters_by_ft.python = { "ruff_format", "ruff_fix" }
      opts.formatters_by_ft.go     = { "gofmt" }
      opts.formatters_by_ft.rust   = { "rustfmt" }
      return opts
    end,
  },
}
